# =============================================================================
# Local development
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# For local Supabase keys: `pnpm supabase:start` then `supabase status -o env`.
#
# Next.js exposes anything prefixed NEXT_PUBLIC_ to the browser bundle.
# NEVER put secrets behind a NEXT_PUBLIC_ prefix.

# --- Browser + server -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only ------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# Slack OAuth — read by the local Supabase Auth container (not by app code).
# 1. Create a Slack app at https://api.slack.com/apps. Under OAuth & Permissions
#    add the redirect URL http://127.0.0.1:54321/auth/v1/callback for local dev
#    (and your production Supabase callback once you have one).
# 2. Paste client id + secret here; Supabase CLI substitutes them into
#    supabase/config.toml on `supabase start`.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# --- api-football (P7) ------------------------------------------------------
API_FOOTBALL_KEY=

# --- Cron auth shared secret (P7) -------------------------------------------
# Any random 32+ char string. Set the same value in Vercel project env.
CRON_SECRET=
