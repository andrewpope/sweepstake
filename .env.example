# =============================================================================
# Local development
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# For local Supabase keys: `pnpm supabase:start` then `supabase status -o env`.
#
# Vite exposes everything prefixed VITE_ to the browser bundle. NEVER put
# secrets behind a VITE_ prefix.
#
# ─── Localhost cookie-jar gotcha ─────────────────────────────────────────────
# Supabase chunks its auth session across two cookies (sb-<ref>-auth-token.0
# and .1). The per-domain cookie quota on browsers is shared across every app
# running on localhost. If you've previously developed another auth-heavy app
# on localhost (Next-Auth, Auth0, etc.) you may have leftover cookies eating
# into that quota, and the browser will silently evict one of the Supabase
# chunks → you sign in successfully but the session "disappears" on the next
# request with error "Auth session missing!".
#
# Fix: DevTools → Application → Cookies → http://localhost:3737 → Clear all.
# Then re-sign-in. Long-term avoidance: map a unique hostname in /etc/hosts.
# ───────────────────────────────────────────────────────────────────────────

# --- Vite (browser + server) -------------------------------------------------
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# --- Server-only -------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# Slack OAuth — read by the local Supabase Auth container (not by app code).
# 1. Create a Slack app at https://api.slack.com/apps (use the "Sign in with
#    Slack" template; under OAuth & Permissions add the redirect URL
#    http://127.0.0.1:54321/auth/v1/callback for local dev, and your
#    production callback once Vercel is live).
# 2. Paste the client id + secret here; the CLI substitutes them into
#    supabase/config.toml on `supabase start`.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# --- api-football (P7) -------------------------------------------------------
API_FOOTBALL_KEY=

# --- Cron auth shared secret (P7) -------------------------------------------
# Any random 32+ char string. Set the same value in Vercel project env.
CRON_SECRET=
