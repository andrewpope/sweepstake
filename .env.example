# Supabase — local dev defaults from `supabase start`
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Slack OAuth (configure in Supabase Auth dashboard → Providers → Slack)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# api-football
API_FOOTBALL_KEY=

# Cron auth shared secret (any random string; set the same value in Vercel)
CRON_SECRET=
